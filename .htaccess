# ================================================================
# Wooden House — .htaccess RAÍZ
# ================================================================
Options -Indexes

<IfModule mod_rewrite.c>
    RewriteEngine On

    # ── Forzar HTTPS (excepto localhost, 127.0.0.1 y proxies que ya terminan SSL) ──
    RewriteCond %{HTTPS} off
    RewriteCond %{HTTP:X-Forwarded-Proto} !=https
    RewriteCond %{HTTP_HOST} !^localhost$ [NC]
    RewriteCond %{HTTP_HOST} !^127\.0\.0\.1$
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # Bloquear carpetas internas sensibles
    RewriteRule ^(includes|database|logs|firebase|\.git|vendor|backup|tmp)(/|$) - [F,L]

    # Nota: No bloqueamos User-Agents vacíos porque PHP/curl internos no siempre los envían
</IfModule>

# Bloquear archivos sensibles
<FilesMatch "\.(env|log|bak|sql|sh|lock|yaml|yml)$">
    Require all denied
</FilesMatch>
<Files ".env">
    Require all denied
</Files>

<IfModule mod_headers.c>
    Header always unset X-Powered-By
    Header always unset Server
    Header always set X-Content-Type-Options "nosniff"
</IfModule>
