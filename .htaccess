# ================================================================
# Wooden House - .htaccess RAIZ DEL PROYECTO
# ================================================================

Options -Indexes

RewriteEngine On

# Redirigir raiz a /public
RewriteRule ^$ /public/ [L,R=301]

# Bloquear acceso directo a carpetas sensibles
RewriteRule ^includes/ - [F,L]
RewriteRule ^database/ - [F,L]
RewriteRule ^logs/     - [F,L]
RewriteRule ^firebase/ - [F,L]

# Bloquear archivos sensibles
<FilesMatch "\.(env|log|bak|sql|sh|lock|yaml|yml)$">
    Require all denied
</FilesMatch>
<Files ".env">
    Require all denied
</Files>