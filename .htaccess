# ================================================================
# Wooden House - .htaccess RAÍZ DEL PROYECTO
# ================================================================
Options -Indexes

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Evitar bucle: si ya estamos dentro de /public/, no redirigir
    RewriteCond %{REQUEST_URI} !^/public/
    # Solo redirigir la raíz exacta (/)
    RewriteRule ^$ /public/ [L,R=302]

    # ── Bloquear carpetas sensibles ──────────────────────────────
    RewriteRule ^includes(/|$)  - [F,L]
    RewriteRule ^database(/|$)  - [F,L]
    RewriteRule ^logs(/|$)      - [F,L]
    RewriteRule ^firebase(/|$)  - [F,L]
    RewriteRule ^\.git(/|$)     - [F,L]
    RewriteRule ^vendor(/|$)    - [F,L]
    RewriteRule ^backup(/|$)    - [F,L]
    RewriteRule ^old(/|$)       - [F,L]
    RewriteRule ^tmp(/|$)       - [F,L]
    RewriteRule ^test(/|$)      - [F,L]

    # ── NOTA: /api/ NO se bloquea aquí ──────────────────────────
    # El proxy de /public/.htaccess redirige internamente a /api/
    # El .htaccess dentro de /api/ controla el acceso directo

    # ── Bloquear User-Agents vacíos (bots simples) ────────────
    RewriteCond %{HTTP_USER_AGENT} ^$
    RewriteRule ^ - [F,L]
</IfModule>

# ── Bloquear archivos sensibles ───────────────────────────────────
<FilesMatch "\.(env|log|bak|sql|sh|lock|yaml|yml)$">
    Require all denied
</FilesMatch>
<Files ".env">
    Require all denied
</Files>
<Files "*.json">
    Require all denied
</Files>

# ── Headers de seguridad mínimos en raíz ─────────────────────────
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header unset X-Powered-By
    Header unset Server
</IfModule>