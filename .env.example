# ================================================================
# Wooden House — Variables de Entorno
#
# INSTRUCCIONES:
# 1. Copia este archivo: cp .env.example .env
# 2. Llena TODOS los valores marcados con < >
# 3. NUNCA subas el .env a Git (ya está en .gitignore)
# 4. En producción usa las variables de entorno del servidor,
#    no el archivo .env
# ================================================================

# ── Entorno ──────────────────────────────────────────────────────
# development → muestra errores PHP
# production  → oculta errores, activa HTTPS, etc.
APP_ENV=development
APP_DEBUG=false
APP_URL=https://tudominio.com

# CORS: URLs que pueden llamar a tu API (tu propio dominio)
# En desarrollo: http://localhost:8080,http://localhost
CORS_ALLOWED_ORIGINS=https://tudominio.com

# ── Base de Datos ─────────────────────────────────────────────────
# NUNCA uses root en producción — crea un usuario con permisos mínimos:
#   CREATE USER 'wh_user'@'localhost' IDENTIFIED BY 'password_fuerte';
#   GRANT SELECT,INSERT,UPDATE,DELETE ON wooden_house.* TO 'wh_user'@'localhost';
DB_HOST=localhost
DB_PORT=3306
DB_NAME=wooden_house
DB_USER=<usuario_mysql_limitado>
DB_PASS=<password_muy_seguro_min_20_chars>

# ── Firebase ──────────────────────────────────────────────────────
# Firebase Console → tu proyecto → Project Settings → General
# El API Key y Project ID son seguros para el frontend (son públicos)
# pero igual los controlamos desde acá para evitar hardcoding
FIREBASE_PROJECT_ID=<tu_project_id>
FIREBASE_API_KEY=<tu_api_key_de_firebase>

# ── Stripe ────────────────────────────────────────────────────────
# dashboard.stripe.com → Developers → API Keys
# Usa pk_test_ / sk_test_ para pruebas, pk_live_ / sk_live_ para producción
STRIPE_PUBLISHABLE_KEY=pk_test_<tu_clave_publica>
STRIPE_SECRET_KEY=sk_test_<tu_clave_secreta>
# dashboard.stripe.com → Developers → Webhooks → tu endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_<tu_webhook_secret>

# ── PayPal ────────────────────────────────────────────────────────
# developer.paypal.com → My Apps & Credentials → Default Application
PAYPAL_CLIENT_ID=<tu_paypal_client_id>
PAYPAL_CLIENT_SECRET=<tu_paypal_client_secret>
# sandbox = pruebas, live = producción
PAYPAL_MODE=sandbox
# developer.paypal.com → My Apps → tu app → Webhooks → copia el Webhook ID
PAYPAL_WEBHOOK_ID=<tu_paypal_webhook_id>

# ── Correos por rol ───────────────────────────────────────────────
# Estos valores también deben configurarse en Firebase Secret Manager:
#   firebase functions:secrets:set NOMBRE_VARIABLE
# Los correos remitentes (pedidos@, citas@, etc.) deben estar
# verificados como remitentes en tu cuenta de Brevo.
ADMIN_EMAIL=<tu_correo_real@gmail.com>         # Recibe BCC de todos los correos
EMAIL_PEDIDOS=pedidos@tudominio.com             # Remitente: confirmaciones de pedidos
EMAIL_CITAS=citas@tudominio.com                 # Remitente: confirmaciones de citas
EMAIL_COTIZACIONES=cotizaciones@tudominio.com   # Remitente: confirmaciones de cotizaciones
EMAIL_VENTAS=ventas@tudominio.com               # Contacto general (footer e index)

# ── Brevo API ─────────────────────────────────────────────────────
# app.brevo.com → SMTP & API → API Keys → Genera una clave
# Esta clave también debe registrarse en Firebase:
#   firebase functions:secrets:set BREVO_API_KEY
BREVO_API_KEY=<tu_brevo_api_key>

# ── Negocio ───────────────────────────────────────────────────────
COSTO_INSTALACION=1500   # Costo de instalación por mueble (MXN)
COSTO_ENVIO=500          # Costo de envío a domicilio (MXN)
LIMITE_DIA=10            # Máximo de muebles a fabricar por día
MARGEN_HABILES=2         # Días hábiles de margen para fecha estimada
SITE_PHONE=<tu_telefono>
SITE_EMAIL=ventas@tudominio.com
