# ================================================================
# Wooden House - .htaccess /api/
# ================================================================
# El DocumentRoot apunta a /public/, por lo que /api/ está FUERA
# del DocumentRoot. Apache puede llegar aquí solo por la
# reescritura interna (../api/$1) del .htaccess de /public/.
# No es necesario bloquear acceso directo porque Apache no sirve
# esta carpeta directamente al estar fuera del DocumentRoot.
# ================================================================

Options -Indexes -ExecCGI

# ── Headers de seguridad para respuestas de la API ────────────────
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set Cache-Control "no-store, no-cache, must-revalidate"
    Header always set Pragma "no-cache"
    Header always set X-Frame-Options "DENY"
</IfModule>

# ── Bloquear archivos sensibles ───────────────────────────────────
<FilesMatch "\.(env|log|bak|sql|sh|lock|yaml|yml|json|txt|md)$">
    Require all denied
</FilesMatch>

# ── Solo permitir métodos HTTP válidos para una API ───────────────
<LimitExcept GET POST PUT DELETE OPTIONS>
    Require all denied
</LimitExcept>