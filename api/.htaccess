# ================================================================
# Wooden House - .htaccess /api/
# /api/ está FUERA del DocumentRoot (/public/).
# Apache llega aquí por el Alias definido en el VirtualHost.
# ================================================================
Options -Indexes -ExecCGI

# ── Suprimir errores PHP en respuestas API ────────────────────────
# Evita que warnings contaminen el JSON de respuesta
php_flag display_errors Off
php_flag display_startup_errors Off

# ── Headers para respuestas API ───────────────────────────────────
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set Cache-Control "no-store, no-cache, must-revalidate"
    Header always set Pragma "no-cache"
    Header always set X-Frame-Options "DENY"
</IfModule>

# ── Bloquear archivos sensibles ───────────────────────────────────
<FilesMatch "\.(env|log|bak|sql|sh|lock|yaml|yml|txt|md)$">
    Require all denied
</FilesMatch>

# ── Solo métodos HTTP válidos para API ────────────────────────────
<LimitExcept GET POST PUT DELETE OPTIONS>
    Require all denied
</LimitExcept>
