# ================================================================
# Wooden House - .htaccess /api/
# ================================================================
# Las peticiones llegan aquí a través del proxy interno de
# /public/.htaccess. Bloqueamos solo el acceso HTTP directo
# usando mod_rewrite (no Require all denied, que en Apache 2.4
# también bloquea las reescrituras internas).
# ================================================================

Options -Indexes -ExecCGI

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Bloquear acceso HTTP directo a /api/ desde el navegador.
    # THE_REQUEST contiene la línea cruda (ej: GET /api/foo.php HTTP/1.1)
    # Si alguien accede directamente, devuelve 403.
    # Las reescrituras internas de mod_rewrite NO usan THE_REQUEST,
    # por lo que el proxy de /public/.htaccess sí funciona.
    RewriteCond %{THE_REQUEST} \s/api/ [NC]
    RewriteRule ^ - [F,L]
</IfModule>

# ── Headers de seguridad para respuestas de la API ────────────────
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set Cache-Control "no-store, no-cache, must-revalidate"
    Header always set Pragma "no-cache"
    Header always set X-Frame-Options "DENY"
</IfModule>

# ── Bloquear archivos sensibles ───────────────────────────────────
<FilesMatch "\.(env|log|bak|sql|sh|lock|yaml|yml|json|txt|md)$">
    Require all denied
</FilesMatch>

# ── Solo permitir métodos HTTP válidos para una API ───────────────
<LimitExcept GET POST PUT DELETE OPTIONS>
    Require all denied
</LimitExcept>