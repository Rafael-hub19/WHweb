# public/uploads/*
# !public/uploads/.gitkeep
# storage/uploads/*
# !storage/uploads/.gitkeep

# === PHP ===
*.php~
*.php.bak

# === TESTS ===
coverage/
.phpunit.result.cache
phpunit.xml

# === OTROS ===
# Carpetas de prueba
test-output/
sandbox/

# Archivos comprimidos (excepto releases)
*.zip
*.tar.gz
*.rar
!releases/*.zip
